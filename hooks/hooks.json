{
  "hooks": {
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PLUGIN_ROOT/bin/ewh.mjs\" record-tool-use --event SubagentStart"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PLUGIN_ROOT/bin/ewh.mjs\" record-tool-use --event SubagentStop"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PLUGIN_ROOT/bin/ewh.mjs\" record-tool-use --event PostToolUse"
          }
        ]
      }
    ]
  }
}
